{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc",
    "start": "bun run dist/index.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "FIREBASE_PROJECT_ID=quartinho-dev GCLOUD_PROJECT=quartinho-dev FIRESTORE_EMULATOR_HOST=127.0.0.1:8085 FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000 BREVO_API_KEY=test BREVO_SENDER_EMAIL=test@quartinho.com MAILDEV_URL=http://127.0.0.1:1080 vitest run src/__tests__/integration/",
    "preflight": "NODE_ENV=preflight bun run scripts/preflight.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-list-endpoints": "^7.1.1",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.3.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "puppeteer": "^24.41.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.1.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-list-endpoints": "^6.0.3",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/node-cron": "^3.0.11",
    "@types/smtp-server": "^3.5.13",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "mailparser": "^3.9.8",
    "smtp-server": "^3.18.4",
    "supertest": "^7.0.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
