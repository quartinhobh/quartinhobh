# ─────────────────────────────────────────────────────────────
# Firebase Admin SDK credentials
# Get from: https://console.firebase.google.com
#   → ⚙️ Project Settings → Service accounts → Generate new private key
#   → save the downloaded JSON at ../private_key.json (gitignored)
#
# RECOMMENDED (local dev): point to the JSON file directly.
# Path is resolved relative to api/ cwd.
# ─────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=../private_key.json

# Alternative (hosted deploys that only accept env vars) — leave the
# SERVICE_ACCOUNT_PATH above empty and fill these three from the JSON:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep quotes and escaped \n literals (config/firebase.ts replaces \\n with \n)
FIREBASE_PRIVATE_KEY=

# Optional: only if using Realtime Database (Firestore doesn't need this)
FIREBASE_DATABASE_URL=

# ─────────────────────────────────────────────────────────────
# Initial admin bootstrap — first user email granted admin role on startup
# ─────────────────────────────────────────────────────────────
INITIAL_ADMIN_EMAIL=

# ─────────────────────────────────────────────────────────────
# MusicBrainz API (Phase 3-B: events + setlist enrichment)
# Docs: https://musicbrainz.org/doc/MusicBrainz_API
# No API key required — only a descriptive User-Agent identifying the app + contact
# Format: AppName/Version (contact-email-or-url)
# ─────────────────────────────────────────────────────────────
MUSICBRAINZ_USER_AGENT=Quartinho/1.0 (contato@exemplo.com)

# ─────────────────────────────────────────────────────────────
# Genius Lyrics API (Phase 3-C: lyrics fetch)
# Get from: https://genius.com/api-clients → New API Client → copy "Client Access Token"
# Docs: https://docs.genius.com/
# ─────────────────────────────────────────────────────────────
GENIUS_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────
# Brevo — email transacional + newsletter (plano grátis: 300/dia)
# Gere em: https://app.brevo.com/settings/keys/api
# Sender: use um email pessoal verificado no Brevo (sem domínio próprio)
# ─────────────────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Quartinho

# URL pública da API (usada no link de unsubscribe dos emails)
API_URL=http://localhost:3001
# URL pública do frontend (usada em links nos emails)
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─────────────────────────────────────────────────────────────
# Firebase Emulator (local dev only — leave empty in production)
# Requires JDK installed: `brew install openjdk`
# Run: `firebase emulators:start`
# ─────────────────────────────────────────────────────────────
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000
