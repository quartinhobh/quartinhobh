rules_version = '2';

// P2-S4: Full per-collection rules. Server-side writes use Firebase Admin SDK
// which bypasses these rules; the rules here are the client-side guard.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isModOrAdmin() {
      return isSignedIn() &&
             (request.auth.token.role == 'moderator' ||
              request.auth.token.role == 'admin');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // Users: read own doc; create own on first login; role changes admin-only.
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.role == 'user';
      allow update: if isAdmin() ||
                    (isSignedIn() && request.auth.uid == userId
                     && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // Sessions: own session only.
    match /sessions/{sessionId} {
      allow read, write: if isSignedIn()
                         && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn();
    }

    // Events: any authenticated read; admin write.
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Votes: authenticated reads of aggregate; writes go through server.
    match /votes/{eventId} {
      allow read: if isSignedIn();
      allow write: if false; // server-side only
    }

    // Lyrics cache: read any authenticated; no client writes.
    match /lyrics_cache/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Bans: mod+admin read/write; delete admin only.
    match /bans/{userId} {
      allow read: if isModOrAdmin();
      allow create, update: if isModOrAdmin();
      allow delete: if isAdmin();
    }

    // Moderation logs: admin read; server-side writes only.
    match /moderation_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Event photos: authenticated read; admin write.
    match /event_photos/{eventId}/{category}/{photoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // RSVPs: authenticated read; writes go through server.
    match /rsvps/{eventId} {
      allow read: if isSignedIn();
      allow write: if false; // server-side only
    }

    // Email templates: admin read/write only (managed via admin panel).
    match /emailTemplates/{templateId} {
      allow read: if isAdmin();
      allow write: if false; // server-side only
    }

    // barSuggestions: public read (list + get); server-side write only (Admin SDK bypasses rules).
    match /barSuggestions/{id} {
      allow read: if true;
      allow write: if false;
    }

    // barFeedbacks: public read of counts; authenticated users can write their own vote doc.
    // Structure: barFeedbacks/{barId}/userVotes/{userId}
    match /barFeedbacks/{barId}/userVotes/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // albumSuggestions: admin read only; server-side write.
    match /albumSuggestions/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // suggestionComments: bar type requires auth for client SDK read;
    // album type requires admin. All writes are server-side only.
    match /suggestionComments/{id} {
      allow read: if resource.data.suggestionType == 'bar'
                     ? request.auth != null
                     : isAdmin();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
